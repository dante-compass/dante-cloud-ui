{
  "name": "herodotus-cloud-ui",
  "private": false,
  "version": "4.0.6.2",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "commit": "git add . && git status && git-cz",
    "push": "pnpm run commit && git push --set-upstream origin develop",
    "dev": "pnpm run --filter=@herodotus/ui dev",
    "prod": "pnpm run --filter=@herodotus/ui prod",
    "shared:build": "pnpm -r --filter=@herodotus-cloud/* run build",
    "pub:changeset": "pnpm changeset",
    "pub:alpha": "pnpm changeset pre enter alpha",
    "pub:beta": "pnpm changeset pre enter beta",
    "pub:rc": "pnpm changeset pre enter rc",
    "pub:exit-pre": "pnpm changeset pre exit",
    "pub:version": "pnpm changeset version",
    "pub:release": "pnpm changeset publish"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "husky-run": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.(js|json|md|scss|ts|vue)": [
      "prettier --write"
    ]
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.15.0"
    }
  },
  "dependencies": {
    "@herodotus/core": "^1.6.1",
    "@quasar/extras": "^1.18.0",
    "disable-devtool": "^0.3.9",
    "filesize": "^11.0.17",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "quasar": "^2.19.3",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@quasar/app-vite": "^2.6.0",
    "@quasar/vite-plugin": "^1.11.0",
    "@rolldown/plugin-node-polyfills": "^1.0.3",
    "@tsconfig/node22": "^22.0.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.2",
    "@types/qs": "^6.15.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.3",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.48.0",
    "rollup": "4.60.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.99.0",
    "typescript": "^6.0.3",
    "unocss": "66.6.8",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.0.0",
    "vconsole": "^3.15.1",
    "vite": "^8.0.11",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-dts": "^5.0.0",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-vconsole": "^2.1.1",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^3.2.8"
  }
}
